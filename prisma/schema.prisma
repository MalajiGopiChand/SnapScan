generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId    String?  @unique
  name           String
  email          String   @unique
  passwordHash   String?
  role           String   @default("GUEST") // SUPER_ADMIN, PHOTOGRAPHER, GUEST
  approvalStatus String   @default("PENDING") // APPROVED, PENDING, REJECTED, SUSPENDED
  
  // Profile fields
  studioName     String?
  phone          String?
  city           String?
  state          String?
  
  // Subscription fields
  subscriptionType   String?  @default("NONE") // NONE, MONTHLY, YEARLY, PAY_PER_EVENT
  subscriptionMethod String?  // RAZORPAY, MANUAL_ADMIN
  subscriptionStatus String   @default("INACTIVE") // INACTIVE, ACTIVE
  razorpayCustomerId String?
  razorpaySubscriptionId String?

  profileImage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  events         Event[]
}

model Event {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId         String   @db.ObjectId
  title           String
  slug            String   @unique
  description     String?
  coverImageUrl   String?
  venue           String?
  city            String?
  state           String?
  country         String?
  eventDate       String?
  pinCode         String?
  guestLink       String?
  qrCodeUrl       String?
  allowDownloads  Boolean  @default(true)
  isPublic        Boolean  @default(false)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  photos          Photo[]
  faceEmbeddings  FaceEmbedding[]
  guestSearches   GuestSearch[]
}

model Photo {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId        String   @db.ObjectId
  originalUrl    String
  optimizedUrl   String?
  thumbnailUrl   String?
  fileName       String
  width          Int?
  height         Int?
  size           Int?
  uploadedAt     DateTime @default(now())

  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  faceEmbeddings FaceEmbedding[]
  matchedPhotos  MatchedPhoto[]
}

model FaceEmbedding {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  photoId         String   @db.ObjectId
  eventId         String   @db.ObjectId
  embeddingVector String?  // Store JSON or encoded array
  boundingBox     String?  // Store JSON {x,y,w,h}
  confidence      Float?
  personIndex     Int?
  createdAt       DateTime @default(now())

  photo           Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model GuestSearch {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId         String   @db.ObjectId
  guestIdentifier String?
  selfieUrl       String
  resultCount     Int      @default(0)
  createdAt       DateTime @default(now())

  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  matchedPhotos   MatchedPhoto[]
}

model MatchedPhoto {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  guestSearchId   String   @db.ObjectId
  photoId         String   @db.ObjectId
  similarityScore Float

  guestSearch     GuestSearch @relation(fields: [guestSearchId], references: [id], onDelete: Cascade)
  photo           Photo       @relation(fields: [photoId], references: [id], onDelete: Cascade)
}

model ClientApprovalLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId  String   @db.ObjectId
  action    String
  notes     String?
  adminId   String   @db.ObjectId
  createdAt DateTime @default(now())
}
